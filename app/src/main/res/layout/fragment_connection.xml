<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo / Header -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_terminal"
            app:tint="@color/md_theme_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ssh_manager"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_on_background"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connect_to_server"
            android:textSize="14sp"
            android:textColor="@color/md_theme_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- Card connessione -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_theme_surface_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Host -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHost"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_host"
                    android:layout_marginBottom="12dp"
                    app:startIconDrawable="@drawable/ic_server">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Porta -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPort"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_port"
                    android:layout_marginBottom="12dp"
                    app:startIconDrawable="@drawable/ic_port">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="22"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Username -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsername"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_username"
                    android:layout_marginBottom="12dp"
                    app:startIconDrawable="@drawable/ic_person">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textNoSuggestions"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_password"
                    android:layout_marginBottom="20dp"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:singleLine="true"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Bottone Connetti -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnect"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_connect"
                    android:textSize="16sp"
                    app:cornerRadius="12dp"/>

                <!-- Progress indicator -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressConnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="@color/md_theme_primary"/>

                <!-- Salva connessione -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveServer"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_save_connection"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Collegati recenti -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSavedServers"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/btn_show_saved_servers"
            app:icon="@drawable/ic_history"/>

        <!-- Errore -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_error"
            android:textColor="@color/md_theme_error"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
