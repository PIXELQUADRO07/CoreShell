<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050505"
    android:padding="12dp"
    android:id="@+id/widget_container">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[ NEURAL_MONITOR ]"
        android:textColor="#00FFD1"
        android:textStyle="bold"
        android:textSize="12sp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/widget_server_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEOTOKYO CORE-1"
        android:textColor="#FF00FF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_host"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IP: 192.168.42.10"
        android:textColor="#888899"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#121216"
        android:layout_marginVertical="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU LOAD: "
            android:textColor="#39FF14"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/widget_cpu_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="||||||||||... 78%"
            android:textColor="#39FF14"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM ALLOC: "
            android:textColor="#FFFFCC00"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/widget_ram_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="|||||...... 42%"
            android:textColor="#FFFFCC00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
    </LinearLayout>

</LinearLayout>
